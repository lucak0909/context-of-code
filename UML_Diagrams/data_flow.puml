    "ts":               "2026-03-11T10:05:00+00:00",
    "latency_eu_ms":    14.2,
    "latency_us_ms":    89.1,
    "latency_asia_ms":  201.4
  }
end note

DB -> PG : INSERT INTO samples (...)
note over PG
  ┌────┬───────────┬───────────────┬────────────┬──────────┬──────────┬──────────┐
  │ id │ device_id │ sample_type   │ latency_ms │ eu_ms    │ us_ms    │ asia_ms  │
  ├────┼───────────┼───────────────┼────────────┼──────────┼──────────┼──────────┤
  │ 43 │ 647f...   │ cloud_latency │ NULL       │ 14.2     │ 89.1     │ 201.4    │
